<mxfile host="app.diagrams.net">
  <diagram id="dfd-ticketing-core" name="DFD Ticketing Core">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="fan" value="Football Fan" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="40" y="80" width="140" height="60" as="geometry"/></mxCell>
        <mxCell id="admin" value="Ticket Admin" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="40" y="260" width="140" height="60" as="geometry"/></mxCell>
        <mxCell id="scan" value="Gate Scan Consumer" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="40" y="440" width="140" height="60" as="geometry"/></mxCell>
        <mxCell id="p1" value="Browse matches&#xa;and select seats" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="300" y="60" width="140" height="90" as="geometry"/></mxCell>
        <mxCell id="p2" value="Hold seats&#xa;and create order" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="520" y="60" width="140" height="90" as="geometry"/></mxCell>
        <mxCell id="p3" value="Confirm payment&#xa;and issue ticket" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="520" y="240" width="140" height="90" as="geometry"/></mxCell>
        <mxCell id="p4" value="Scan ticket" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="520" y="420" width="140" height="90" as="geometry"/></mxCell>
        <mxCell id="store" value="D1 PostgreSQL&#xa;users, matches, seats, orders, tickets, audit_logs" style="shape=partialRectangle;whiteSpace=wrap;html=1;right=0;" vertex="1" parent="1"><mxGeometry x="800" y="190" width="260" height="140" as="geometry"/></mxCell>
        <mxCell id="d1" value="match / seat request" style="endArrow=block;html=1;rounded=0;jumpStyle=arc;" edge="1" parent="1" source="fan" target="p1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d2" value="selected seats" style="endArrow=block;html=1;rounded=0;jumpStyle=arc;" edge="1" parent="1" source="p1" target="p2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d3" value="seat/order writes" style="endArrow=block;html=1;rounded=0;jumpStyle=arc;" edge="1" parent="1" source="p2" target="store"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d4" value="payment decision" style="endArrow=block;html=1;rounded=0;jumpStyle=arc;" edge="1" parent="1" source="admin" target="p3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d5" value="ticket issue / audit" style="endArrow=block;html=1;rounded=0;jumpStyle=arc;" edge="1" parent="1" source="p3" target="store"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d6" value="scan request" style="endArrow=block;html=1;rounded=0;jumpStyle=arc;" edge="1" parent="1" source="scan" target="p4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d7" value="ticket status update" style="endArrow=block;html=1;rounded=0;jumpStyle=arc;" edge="1" parent="1" source="p4" target="store"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

