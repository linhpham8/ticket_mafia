<mxfile host="app.diagrams.net">
  <diagram name="Local fallback DFD">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="fan" value="Football Fan" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="60" y="160" width="140" height="60" as="geometry"/></mxCell>
        <mxCell id="p1" value="Fetch match/seat read data" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="310" y="145" width="140" height="90" as="geometry"/></mxCell>
        <mxCell id="backend" value="Backend API" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="560" y="70" width="150" height="60" as="geometry"/></mxCell>
        <mxCell id="db" value="PostgreSQL&#xa;source of truth" style="shape=partialRectangle;whiteSpace=wrap;html=1;right=0;left=0;" vertex="1" parent="1"><mxGeometry x="820" y="70" width="170" height="70" as="geometry"/></mxCell>
        <mxCell id="p2" value="Apply fallback gate" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="560" y="250" width="140" height="90" as="geometry"/></mxCell>
        <mxCell id="fallback" value="Local Demo Dataset&#xa;display only" style="shape=partialRectangle;whiteSpace=wrap;html=1;right=0;left=0;" vertex="1" parent="1"><mxGeometry x="820" y="260" width="180" height="70" as="geometry"/></mxCell>
        <mxCell id="p3" value="Render fallback state" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="560" y="430" width="140" height="90" as="geometry"/></mxCell>
        <mxCell id="e1" value="open match list / seat map" style="endArrow=block;html=1;rounded=0;jumpStyle=arc;" edge="1" parent="1" source="fan" target="p1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="GET matches/seats" style="endArrow=block;html=1;rounded=0;jumpStyle=arc;" edge="1" parent="1" source="p1" target="backend"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="authoritative rows" style="endArrow=block;html=1;rounded=0;jumpStyle=arc;" edge="1" parent="1" source="backend" target="db"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="error / empty / timeout" style="endArrow=block;html=1;rounded=0;jumpStyle=arc;" edge="1" parent="1" source="p1" target="p2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="fallback read request" style="endArrow=block;html=1;rounded=0;jumpStyle=arc;" edge="1" parent="1" source="p2" target="fallback"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="demo rows + fallback flag" style="endArrow=block;html=1;rounded=0;jumpStyle=arc;" edge="1" parent="1" source="fallback" target="p3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" value="visible fallback UI" style="endArrow=block;html=1;rounded=0;jumpStyle=arc;" edge="1" parent="1" source="p3" target="fan"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
