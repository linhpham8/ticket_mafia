# Copy this to .env and fill in your values
ATLASSIAN_EMAIL=your@email.com
ATLASSIAN_API_TOKEN=your_api_token
ATLASSIAN_BASE_URL=https://your-domain.atlassian.net/
CONFLUENCE_SPACE_KEY=
JIRA_PROJECT_KEY=
QMETRY_API_TOKEN=

# Robot Framework — output đúng thư mục (set 1 lần trong terminal/CI)
# PowerShell: $env:ROBOT_OPTIONS = "--outputdir testing-output/reports"
# Bash/CI:    export ROBOT_OPTIONS="--outputdir testing-output/reports"
# Sau khi set, lệnh `robot ...` bất kỳ sẽ tự dùng outputdir này.
# KHUYẾN NGHỊ: dùng .\run_robot.ps1 (Windows) hoặc bash run_tests.sh (Linux/CI)
FDP_BASE_URL=https://staging.fdp.onemount.com
KEYCLOAK_BASE_URL=https://keycloak.staging.fdp.onemount.com
KEYCLOAK_REALM=fdp-staging
KEYCLOAK_CLIENT_ID=fdp-portal
SP_TEST_CLIENT_SECRET=
SP_PARENT_USER_ID=
